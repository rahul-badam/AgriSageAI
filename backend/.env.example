# Optional: set either or both. Gemini is tried first.
GEMINI_API_KEY=
OPENAI_API_KEY=
CLERK_SECRET_KEY=

# Optional: comma-separated list of allowed origins.
# Default is *
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional app port override (mainly useful for containers/platforms).
PORT=8000
